# deploy/Dockerfile.ollama
# Standalone Ollama image for DevOps AI Copilot with pre-downloaded offline model.
# Best models for 4GB RAM: llama3.2:3b, mistral:7b, phi3:3.8b, qwen2.5:7b
# This image is used by the devops-ai-copilot when LLM_PROVIDER=ollama
FROM ollama/ollama:latest

LABEL org.opencontainers.image.title="devops-ai-copilot-ollama"
LABEL org.opencontainers.image.description="Ollama with DevOps-optimized 4GB LLM model for DevOps AI Copilot"
LABEL org.opencontainers.image.source="https://github.com/WhoisMonesh/devops-ai-copilot"

# 4GB-class models available:
#   mistral:7b       - Excellent all-around (recommended for DevOps)
#   llama3.2:3b      - Efficient, good quality
#   phi3:3.8b        - Microsoft Phi-3, very capable
#   qwen2.5:7b       - Alibaba Qwen, strong coding
ARG OLLAMA_MODEL=mistral:7b
ENV OLLAMA_MODEL=${OLLAMA_MODEL}

# Pre-pull the model at build time for offline use
# This ensures the model is baked into the image
RUN ollama pull ${OLLAMA_MODEL}

# Health check - verify ollama is responding and model is available
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

EXPOSE 11434

# Run ollama serve (the default entrypoint for ollama/ollama image)
CMD ["serve"]
