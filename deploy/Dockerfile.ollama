# deploy/Dockerfile.ollama
# Standalone Ollama image for DevOps AI Copilot with pre-downloaded offline model.
# This image works COMPLETELY OFFLINE - no internet required at runtime.
# Build-time internet only required to pull the model initially.
FROM ollama/ollama:latest

LABEL org.opencontainers.image.title="devops-ai-copilot-ollama"
LABEL org.opencontainers.image.description="Ollama with DevOps-optimized 4GB LLM model for DevOps AI Copilot - Offline capable"
LABEL org.opencontainers.image.source="https://github.com/WhoisMonesh/devops-ai-copilot"

# 3GB-class models available:
#   qwen2.5:3b       - Alibaba Qwen, excellent coding & reasoning ~2GB (CI default)
#   mistral:7b      - Excellent all-around (recommended for production) ~4.4GB
ARG OLLAMA_MODEL=qwen2.5:3b
ENV OLLAMA_MODEL=${OLLAMA_MODEL}

# Pre-download the model at BUILD TIME for offline use
# The model is baked directly into the image - no internet needed at runtime
# Build command: docker build --build-arg OLLAMA_MODEL=mistral:7b -t my-ollama .
RUN bash -c 'echo "=== Downloading model ${OLLAMA_MODEL} for offline use ===" && \
    OLLAMA_HOST= ollama pull ${OLLAMA_MODEL} && \
    echo "Model ${OLLAMA_MODEL} downloaded successfully"'

# Health check - verify ollama is responding
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

EXPOSE 11434

# Run ollama serve (the default entrypoint for ollama/ollama image)
CMD ["serve"]
