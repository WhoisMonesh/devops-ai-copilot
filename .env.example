# =============================================================================
# DevOps AI Copilot - Environment Variables
# Copy this file to .env and fill in real values. Never commit .env!
# =============================================================================

# ------------------------------------------------------------
# LLM Provider: ollama | vertexai | bedrock  (default: ollama)
# ------------------------------------------------------------
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# --- Vertex AI / Gemini (GCP) ---
VERTEXAI_PROJECT=my-gcp-project
VERTEXAI_LOCATION=us-central1
VERTEXAI_MODEL=gemini-1.5-pro
VERTEXAI_TEMPERATURE=0.2
VERTEXAI_MAX_TOKENS=2048
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# --- AWS Bedrock ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_TEMPERATURE=0.2
BEDROCK_MAX_TOKENS=2048
# Uses IAM role / instance profile - no keys needed in EKS with IRSA

# ------------------------------------------------------------
# AWS Secrets Manager - Secret ARNs or names
# Store ALL credentials (passwords, tokens, certs) here
# ------------------------------------------------------------
SECRET_ID_JENKINS=devops-copilot/jenkins
SECRET_ID_KIBANA=devops-copilot/kibana
SECRET_ID_ARTIFACTORY=devops-copilot/artifactory
SECRET_ID_NGINX=devops-copilot/nginx
SECRET_ID_VERTEXAI=devops-copilot/vertexai
SECRET_ID_BEDROCK=devops-copilot/bedrock
SECRET_CACHE_TTL=300

# ------------------------------------------------------------
# Infra URLs (non-sensitive - safe to put in env)
# ------------------------------------------------------------
NGINX_URL=http://nginx.internal:80
KIBANA_URL=http://kibana.internal:5601
ELASTICSEARCH_URL=http://elasticsearch.internal:9200
JENKINS_URL=http://jenkins.internal:8080
ARTIFACTORY_URL=http://artifactory.internal:8082
PROMETHEUS_URL=http://prometheus.internal:9090
GRAFANA_URL=http://grafana.internal:3000
K8S_IN_CLUSTER=false
K8S_NAMESPACE=default
K8S_KUBECONFIG_PATH=~/.kube/config

# ------------------------------------------------------------
# FastAPI Agent
# ------------------------------------------------------------
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_RELOAD=true
LOG_LEVEL=info

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# API key for authenticating GUI and external clients to the agent
# Generate with: openssl rand -hex 32
API_KEY=

# ------------------------------------------------------------
# Streamlit GUI
# ------------------------------------------------------------
AGENT_API_URL=http://localhost:8000
AGENT_API_KEY=

# ------------------------------------------------------------
# Grafana (for Grafana tool integration)
# ------------------------------------------------------------
GRAFANA_API_KEY=

# ------------------------------------------------------------
# Cache Configuration
# ------------------------------------------------------------
# CACHE_TTL=300         # Query cache TTL in seconds
# CACHE_MAX_SIZE=500    # Maximum query cache entries
